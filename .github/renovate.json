{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:enableMajor",
    ":disableRateLimiting",
    ":dependencyDashboard",
    ":semanticCommits",
    ":skipStatusChecks",
    ":timezone(Asia/Makassar)"
  ],
  "dependencyDashboardTitle": "Renovate Dashboard 🤖",
  "packageRules": [
    {
      "matchPackageNames": "*",
      "matchUpdateTypes": ["minor", "patch"]
    }
  ]
}
