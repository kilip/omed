{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": ["OMED_SECRET", "OMED_API_URL"],
  "tasks": {
    "build": {
      "env": ["OMED_SECRET", "OMED_API_URL"],
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".react-router/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "dependsOn": ["^build"]
    }
  }
}
